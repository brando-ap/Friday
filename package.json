{
  "name": "task-tracker",
  "private": true,
  "version": "0.1.0",
  "description": "Personal task/project tracker — Cloudflare Worker (Hono) + Supabase + React.",
  "workspaces": [
    "worker",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c magenta,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm --workspace worker run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace web run build",
    "check:api": "npm --workspace worker run build",
    "deploy:api": "npm --workspace worker run deploy",
    "deploy:web": "npm --workspace web run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
