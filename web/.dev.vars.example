# Copy this file to `web/.dev.vars` and fill in the values.

# --- Supabase ---
#   SUPABASE_URL        = the "Project URL"  (Project Settings -> API)
#   SUPABASE_SECRET_KEY = a "secret" API key starting with sb_secret_
#                         (Project Settings -> API Keys -> Secret keys -> Create new)
# The secret key has full access and bypasses Row Level Security, so it must stay
# server-side only. This replaces the legacy "service_role" key.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."

# --- Auth ---
#   APP_PASSWORD = the password you'll type to log in
#   JWT_SECRET   = a long random string used to sign session tokens. Generate one with:
#                  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
APP_PASSWORD="choose-a-strong-password"
JWT_SECRET="paste-a-long-random-string"
