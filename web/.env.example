# Copy this file to `web/.env` and fill in the values.
# These are build-time Vite vars, baked into the client bundle — safe to be public,
# since the publishable key only grants access to Supabase Auth, protected by
# the fact that every actual data table has RLS enabled with no policies (see
# web/schema.sql) — only the server-side Worker (secret key) can touch data.

# Project Settings -> API
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
# Project Settings -> API Keys -> "publishable" key (the new name for "anon" key)
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
